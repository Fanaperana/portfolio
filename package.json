{
  "name": "portfolio",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "wasm": "wasm-pack build crates/mini-shell --target web --out-dir pkg --release",
    "wasm:dev": "wasm-pack build crates/mini-shell --target web --out-dir pkg --dev",
    "dev": "vite",
    "build": "pnpm wasm && vite build",
    "preview": "vite preview",
    "check": "svelte-check --tsconfig ./tsconfig.app.json && tsc -p tsconfig.node.json",
    "test:rust": "cargo test -p mini-shell"
  },
  "devDependencies": {
    "@fontsource-variable/inter": "^5.2.8",
    "@internationalized/date": "^3.12.0",
    "@lucide/svelte": "^1.8.0",
    "@sveltejs/vite-plugin-svelte": "^7.0.0",
    "@tailwindcss/vite": "^4.2.2",
    "@tsconfig/svelte": "^5.0.8",
    "@types/node": "^24.12.2",
    "bits-ui": "^2.16.3",
    "clsx": "^2.1.1",
    "esbuild": "^0.28.0",
    "rollup": "^4.60.2",
    "shadcn-svelte": "^1.2.7",
    "svelte": "^5.55.1",
    "svelte-check": "^4.4.6",
    "tailwind-merge": "^3.5.0",
    "tailwind-variants": "^3.2.2",
    "tailwindcss": "^4.2.2",
    "tw-animate-css": "^1.4.0",
    "typescript": "~6.0.2",
    "vite": "^8.0.4",
    "vite-plugin-wasm": "^3.6.0"
  }
}
